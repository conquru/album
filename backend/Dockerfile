# 1. Задаем базовый образ
FROM node:20-alpine

# 2. Устанавливаем рабочую директорию внутри контейнера
WORKDIR /app

# 3. Копируем файлы с зависимостями
COPY package.json ./

# 4. Устанавливаем зависимости
RUN npm install --omit=dev

# 5. Копируем остальные файлы проекта
COPY /src ./src
RUN mkdir -p /app/uploads
# 6. Указываем порт, который будет слушать приложение
EXPOSE 4000

# 7. Команда, запускающая приложение при старте контейнера
CMD ["node", "src/index.js"]

